local dragStartMouse = Vector2.new()

MoveBtn.MouseButton1Down:Connect(function()
    isDragging = true
    dragStartPos = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset,
                            MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset)
    dragStartMouse = Vector2.new(UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)

RunService.RenderStepped:Connect(function()
    if isDragging then
        local currentMouse = Vector2.new(UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
        local delta = currentMouse - dragStartMouse
        MainFrame.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X,
                                      dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
    end
end)

-- ===== ВКЛАДКИ (RuzHub стиль) =====
local Tabs = {}
local TabButtons = {}
local TabContents = {}

local function CreateTab(name, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 110, 0, 40)
    btn.Position = UDim2.new(0.5, -165 + (#TabButtons * 115), 0, 55)
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.3
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.Parent = MainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, -20, 1, -140)
    content.Position = UDim2.new(0, 10, 0, 100)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.CanvasSize = UDim2.new(0, 0, 0, 600)
    content.ScrollBarThickness = 4
    content.Parent = MainFrame
    
    TabButtons[name] = btn
    TabContents[name] = content
    table.insert(Tabs, name)
    
    btn.MouseButton1Click:Connect(function()
        for _, tab in ipairs(Tabs) do
            TabContents[tab].Visible = false
            TabButtons[tab].BackgroundTransparency = 0.3
        end
        content.Visible = true
        btn.BackgroundTransparency = 0
    end)
    
    return content
end

