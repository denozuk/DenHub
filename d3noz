CreateToggle(tab1, "Авто-убийство всех", 65, function(state)
    autoKillEnabled = state
    if state then
        spawn(function()
            while autoKillEnabled do
                wait(0.1)
                local murderers = {}
                for _, v in ipairs(game.Players:GetPlayers()) do
                    if v ~= Player and v.Team and v.Team.Name == "Murderer" then
                        table.insert(murderers, v)
                    end
                end
                for _, murderer in ipairs(murderers) do
                    if murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart") then
                        local args = {
                            [1] = murderer.Character.HumanoidRootPart.Position
                        }
                        game:GetService("ReplicatedStorage"):WaitForChild("Kill"):FireServer(unpack(args))
                    end
                end
            end
        end)
    end
end)

