-- ESP
CreateToggle(tab1, "ESP (Игроки)", 35, function(state)
    espEnabled = state
    if state then
        -- Включаем ESP
        game:GetService("RunService").Stepped:Connect(function()
            if not espEnabled then return end
            for _, v in ipairs(game.Players:GetPlayers()) do
                if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local esp = Instance.new("BillboardGui")
                    esp.Name = "ESP_"..v.Name
                    esp.Size = UDim2.new(0, 200, 0, 50)
                    esp.AlwaysOnTop = true
                    esp.Parent = v.Character.HumanoidRootPart
                    
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.Text = v.Name
                    label.TextScaled = true
                    label.BackgroundTransparency = 0.3
                    label.Parent = esp
                    
                    -- Определяем цвет по роли
                    local role = "Невинный"
                    if v.Team then
                        if v.Team.Name == "Murderer" then
                            label.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Красный
                            role = "Убийца"
                        elseif v.Team.Name == "Sheriff" then
                            label.BackgroundColor3 = Color3.fromRGB(0, 0, 255) -- Синий
                            role = "Шериф"
                        elseif v.Team.Name == "Hero" then
                            label.BackgroundColor3 = Color3.fromRGB(255, 255, 0) -- Желтый
                            role = "Герой"
                        else
                            label.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Черный
                        end
                    end
                    
                    -- Удаляем старые ESP
                    for _, espObj in ipairs(v.Character.HumanoidRootPart:GetChildren()) do
                        if string.find(espObj.Name, "ESP_") and espObj ~= esp then
                            espObj:Destroy()
                        end
                    end
                end
            end
        end)
    else
        -- Удаляем ESP
        for _, v in ipairs(game.Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                for _, esp in ipairs(v.Character.HumanoidRootPart:GetChildren()) do
                    if string.find(esp.Name, "ESP_") then
                        esp:Destroy()
                    end
                end
            end
        end
    end
end)

