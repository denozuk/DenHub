local function saveConfig()
    local json = HttpService:JSONEncode(config)
    setclipboard and setclipboard(json) or print("Config saved to clipboard")
    _G.SWILL_Config = json
end

local function loadConfig()
    local json = _G.SWILL_Config or (getclipboard and getclipboard())
    if json then
        local success, data = pcall(function() return HttpService:JSONDecode(json) end)
        if success and data then
            for k,v in pairs(data) do
                if type(v) == "table" and type(config[k]) == "table" then
                    for subk, subv in pairs(v) do
                        config[k][subk] = subv
                    end
                else
                    config[k] = v
                end
            end
        end
    end
end
